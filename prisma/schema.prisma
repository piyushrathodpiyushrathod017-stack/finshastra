generator client {
  provider = "prisma-client-js"
  output   = "../src/generated/prisma"
}

datasource db {
  provider = "postgresql"
}

enum Role {
  ADMIN
  EDITOR
  AUTHOR
}

enum AdminRole {
  SUPER_ADMIN
  ADMIN
  EDITOR
  AUTHOR
  REVIEWER
}

enum ArticleStatus {
  DRAFT
  REVIEW
  APPROVED
  PUBLISHED
  ARCHIVED
  SCHEDULED
}

model Author {
  id        String   @id @default(cuid())
  name      String
  email     String   @unique
  avatar    String?
  bio       String?
  role      Role     @default(AUTHOR)
  social    Json?
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  articles         Article[]
  reviewedArticles Article[] @relation("ArticleReviewer")

  @@index([email])
}

model Category {
  id              String   @id @default(cuid())
  name            String
  slug            String   @unique
  description     String?
  parentId        String?
  metaTitle       String?
  metaDescription String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  parent   Category?  @relation("CategoryHierarchy", fields: [parentId], references: [id])
  children Category[] @relation("CategoryHierarchy")
  articles Article[]

  @@index([slug])
  @@index([parentId])
}

model Article {
  id              String        @id @default(cuid())
  title           String
  slug            String        @unique
  excerpt         String?
  content         String
  coverImage      String?
  authorId        String
  categoryId      String
  tags            String[]
  metaTitle       String?
  metaDescription String?
  isPublished     Boolean       @default(false)
  isFeatured      Boolean       @default(false)
  readingTime     Int           @default(5)
  views           Int           @default(0)
  publishedAt     DateTime?
  status          ArticleStatus @default(DRAFT)
  scheduledAt     DateTime?
  reviewerId      String?
  qualityScore    Int?
  createdAt       DateTime      @default(now())
  updatedAt       DateTime      @updatedAt

  author     Author   @relation(fields: [authorId], references: [id])
  category   Category @relation(fields: [categoryId], references: [id])
  reviewer   Author?  @relation("ArticleReviewer", fields: [reviewerId], references: [id])
  faqs       FAQ[]
  revisions  ArticleRevision[]
  articleTags ArticleTag[]

  @@index([slug])
  @@index([authorId])
  @@index([categoryId])
  @@index([isPublished])
  @@index([isFeatured])
  @@index([publishedAt])
  @@index([status])
  @@index([reviewerId])
}

model Bank {
  id            String   @id @default(cuid())
  name          String
  slug          String   @unique
  logo          String?
  website       String?
  description   String?
  rating        Float    @default(0)
  features      String[]
  pros          String[]
  cons          String[]
  interestRate  String?
  processingFee String?
  minLoanAmount Int?
  maxLoanAmount Int?
  minCreditScore Int?
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt

  comparisons ComparisonItem[]

  @@index([slug])
  @@index([rating])
}

model Calculator {
  id          String   @id @default(cuid())
  name        String
  slug        String   @unique
  description String?
  icon        String?
  category    String?
  inputs      Json?
  createdAt   DateTime @default(now())
  updatedAt   DateTime @updatedAt

  @@index([slug])
}

model FAQ {
  id        String   @id @default(cuid())
  question  String
  answer    String
  category  String?
  articleId String?
  order     Int      @default(0)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  article Article? @relation(fields: [articleId], references: [id])

  @@index([articleId])
  @@index([category])
}

model Newsletter {
  id            String    @id @default(cuid())
  email         String    @unique
  name          String?
  isSubscribed  Boolean   @default(true)
  subscribedAt  DateTime  @default(now())
  unsubscribedAt DateTime?
  createdAt     DateTime  @default(now())

  @@index([email])
  @@index([isSubscribed])
}

model Contact {
  id        String   @id @default(cuid())
  name      String
  email     String
  subject   String
  message   String
  isRead    Boolean  @default(false)
  createdAt DateTime @default(now())

  @@index([email])
  @@index([isRead])
  @@index([createdAt])
}

model PageView {
  id        String   @id @default(cuid())
  path      String
  referrer  String?
  userAgent String?
  ip        String?
  country   String?
  createdAt DateTime @default(now())

  @@index([path])
  @@index([createdAt])
}

model Redirect {
  id         String   @id @default(cuid())
  from       String   @unique
  to         String
  statusCode Int      @default(301)
  isActive   Boolean  @default(true)
  createdAt  DateTime @default(now())

  @@index([from])
  @@index([isActive])
}

model Comparison {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  description     String?
  metaTitle       String?
  metaDescription String?
  isPublished     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  items ComparisonItem[]

  @@index([slug])
  @@index([isPublished])
}

model ComparisonItem {
  id           String @id @default(cuid())
  comparisonId String
  bankId       String
  features     Json?
  rating       Float  @default(0)
  order        Int    @default(0)

  comparison Comparison @relation(fields: [comparisonId], references: [id])
  bank       Bank       @relation(fields: [bankId], references: [id])

  @@unique([comparisonId, bankId])
  @@index([comparisonId])
  @@index([bankId])
}

model ProgrammaticPage {
  id              String   @id @default(cuid())
  title           String
  slug            String   @unique
  description     String?
  template        String
  data            Json?
  metaTitle       String?
  metaDescription String?
  isPublished     Boolean  @default(false)
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  @@index([slug])
  @@index([template])
  @@index([isPublished])
}

// ============================================================================
// ADMIN MODELS
// ============================================================================

model AdminUser {
  id              String    @id @default(cuid())
  email           String    @unique
  name            String
  passwordHash    String
  role            AdminRole @default(AUTHOR)
  isActive        Boolean   @default(true)
  mfaEnabled      Boolean   @default(false)
  mfaSecret       String?
  lastLoginAt     DateTime?
  lastLoginIp     String?
  failedAttempts  Int       @default(0)
  lockedUntil     DateTime?
  createdAt       DateTime  @default(now())
  updatedAt       DateTime  @updatedAt

  sessions          AdminSession[]
  articleRevisions  ArticleRevision[]
  auditLogs         AuditLog[]

  @@index([email])
  @@index([role])
  @@index([isActive])
}

model AdminSession {
  id           String   @id @default(cuid())
  userId       String
  tokenHash    String
  refreshToken String   @unique
  ip           String?
  userAgent    String?
  isActive     Boolean  @default(true)
  expiresAt    DateTime
  createdAt    DateTime @default(now())

  user AdminUser @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([tokenHash])
  @@index([refreshToken])
  @@index([expiresAt])
  @@index([isActive])
}

model ArticleRevision {
  id          String   @id @default(cuid())
  articleId   String
  authorId    String
  title       String
  content     String
  excerpt     String?
  metaTitle   String?
  metaDescription String?
  changeNote  String?
  createdAt   DateTime @default(now())

  article Article     @relation(fields: [articleId], references: [id], onDelete: Cascade)
  author  AdminUser   @relation(fields: [authorId], references: [id])

  @@index([articleId])
  @@index([authorId])
  @@index([createdAt])
}

model Tag {
  id        String   @id @default(cuid())
  name      String   @unique
  slug      String   @unique
  color     String?
  createdAt DateTime @default(now())

  articleTags ArticleTag[]

  @@index([slug])
}

model ArticleTag {
  articleId String
  tagId     String
  createdAt DateTime @default(now())

  article Article @relation(fields: [articleId], references: [id], onDelete: Cascade)
  tag     Tag     @relation(fields: [tagId], references: [id], onDelete: Cascade)

  @@id([articleId, tagId])
  @@index([articleId])
  @@index([tagId])
}

model Media {
  id          String   @id @default(cuid())
  filename    String
  originalName String
  mimeType    String
  size        Int
  url         String
  alt         String?
  uploadedBy  String?
  createdAt   DateTime @default(now())

  @@index([mimeType])
  @@index([uploadedBy])
  @@index([createdAt])
}

model Setting {
  id        String   @id @default(cuid())
  key       String   @unique
  value     String
  updatedAt DateTime @updatedAt

  @@index([key])
}

model AuditLog {
  id         String   @id @default(cuid())
  userId     String?
  action     String
  entityType String
  entityId   String?
  details    Json?
  ip         String?
  userAgent  String?
  createdAt  DateTime @default(now())

  user AdminUser? @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([userId])
  @@index([action])
  @@index([entityType])
  @@index([entityId])
  @@index([createdAt])
}

model SEOMeta {
  id              String @id @default(cuid())
  entityType      String
  entityId        String
  metaTitle       String?
  metaDescription String?
  canonicalUrl    String?
  ogImage         String?
  noindex         Boolean @default(false)
  nofollow        Boolean @default(false)

  @@unique([entityType, entityId])
  @@index([entityType])
  @@index([entityId])
}

model InternalLink {
  id          String @id @default(cuid())
  sourceUrl   String
  targetUrl   String
  anchorText  String
  isBroken    Boolean @default(false)
  lastChecked DateTime?
  createdAt   DateTime @default(now())

  @@index([sourceUrl])
  @@index([targetUrl])
  @@index([isBroken])
}
